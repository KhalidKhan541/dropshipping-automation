{
  "name": "dropshipping-automation",
  "version": "1.0.0",
  "description": "Cloudflare Workers automation for Pakistan dropshipping business",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute dropshipping-db --file=./migrations/0001_init.sql",
    "db:seed": "wrangler d1 execute dropshipping-db --file=./migrations/0002_seed.sql",
    "db:reset": "wrangler d1 execute dropshipping-db --file=./migrations/0001_init.sql --remote",
    "tail": "wrangler tail",
    "test": "vitest"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "wrangler": "^3.22.0"
  }
}
